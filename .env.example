# Salin file ini jadi .env.local lalu isi dengan nilai asli dari Supabase Dashboard
# (Project Settings > API). JANGAN commit file .env.local ke Git.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=

IP_HASH_SALT=

# Cloudflare Turnstile - Site Key publik (aman di client).
# Secret Key TIDAK ditaruh di sini - itu diisi langsung di Supabase Dashboard
# > Authentication > Attack Protection > Enable CAPTCHA protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
